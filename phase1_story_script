# ── Shared state ──────────────────────────────────────────────────────────────
class WriterState(TypedDict):
    mode: str                           # "manual" | "autonomous"
    raw_input: str                      # prompt or uploaded script text
    scene_manifest: List[Dict[str, Any]]
    character_db: Dict[str, Any]
    feedback: str                       # validator / HITL messages
    approved: bool                      # HITL gate
    messages: List[str]                 # agent activity log


# ── LLM bootstrap – per-agent model selection ─────────────────────────────────
def get_llm_for_agent(agent_name: str) -> Optional[ChatGroq]:
    """
    Return a ChatGroq instance using the model specifically assigned to the
    given agent.  Falls back through FALLBACK_MODELS if the preferred model
    is unavailable.
    """
    api_key = os.getenv("GROQ_API_KEY", "").strip()
    if not api_key:
        return None

    preferred = AGENT_MODELS.get(agent_name)
    order = ([preferred] if preferred else []) + [
        m for m in FALLBACK_MODELS if m != preferred
    ]

    for model in order:
        try:
            llm = ChatGroq(temperature=0.7, model_name=model, groq_api_key=api_key)
            llm.invoke([HumanMessage(content="ping")])
            print(f"[LLM:{agent_name}] Using model: {model}")
            return llm
        except Exception as exc:
            print(f"[LLM:{agent_name}] {model} unavailable: {exc}")
    return None


# ── MCP helper ────────────────────────────────────────────────────────────────
async def call_mcp_tool(session: ClientSession, tool_name: str, args: dict) -> str:
    """Dynamically discover and call a named MCP tool."""
    tools_resp = await session.list_tools()
    available = {t.name for t in tools_resp.tools}
    if tool_name not in available:
        return json.dumps({"error": f"Tool '{tool_name}' not found in MCP registry"})
    result = await session.call_tool(tool_name, arguments=args)
    return result.content[0].text if result.content else "{}"


async def list_mcp_tools(session: ClientSession) -> List[str]:
    resp = await session.list_tools()
    return [t.name for t in resp.tools]


# ── LLM + MCP chain (with LLM-driven tool selection when key present) ─────────
async def llm_with_mcp(
    session: ClientSession,
    llm: Optional[ChatGroq],
    system_prompt: str,
    user_prompt: str,
    allowed_tools: List[str],
) -> tuple[str, List[tuple[str, str]]]:
    """
    If a live LLM is available:  ask it to reason + emit tool_calls.
    Otherwise:                   fall through to deterministic mock calls.
    Returns (llm_text_response, [(tool_name, tool_result), ...])
    """
    tools_resp = await session.list_tools()
    schemas = [
        {
            "type": "function",
            "function": {
                "name": t.name,
                "description": t.description,
                "parameters": t.inputSchema,
            },
        }
        for t in tools_resp.tools
        if t.name in allowed_tools
    ]

    tool_results: List[tuple[str, str]] = []
    response_text = ""

    if llm:
        llm_tools = llm.bind_tools(schemas)
        response = llm_tools.invoke([
            SystemMessage(content=system_prompt),
            HumanMessage(content=user_prompt),
        ])
        response_text = response.content or ""

        for tc in getattr(response, "tool_calls", []):
            name, args = tc["name"], tc["args"]
            if name in allowed_tools:
                print(f"  [MCP Call] {name}({args})")
                raw = await call_mcp_tool(session, name, args)
                tool_results.append((name, raw))
    else:
        print("  [offline mock mode – no GROQ_API_KEY]")

    return response_text, tool_results


