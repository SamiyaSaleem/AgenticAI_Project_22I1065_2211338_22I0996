def get_llm(role: str) -> Optional[ChatGroq]:
    api_key = os.getenv("GROQ_API_KEY", "").strip()
    if not api_key:
        return None
    try:
        model = MODELS.get(role, "llama-3.1-8b-instant")
        return ChatGroq(temperature=0.7, model_name=model, groq_api_key=api_key)
    except Exception:
        return ChatGroq(temperature=0.7, model_name="llama-3.1-8b-instant", groq_api_key=api_key)


async def call_mcp_tool(session: ClientSession, tool_name: str, args: dict) -> str:
    tools_resp = await session.list_tools()
    available = {t.name for t in tools_resp.tools}
    if tool_name not in available:
        return json.dumps({"error": f"Tool '{tool_name}' not found in MCP registry"})
    result = await session.call_tool(tool_name, arguments=args)
    return result.content[0].text if result.content else "{}"


def load_json(filename: str) -> Any:
    filepath = os.path.join(OUTPUT_DIR, filename)
    if os.path.exists(filepath):
        with open(filepath, "r", encoding="utf-8") as f:
            return json.load(f)
    return None


def find_character_image(char_name: str, scene_id: str) -> str:
    """Resolve best image path for a character in the given scene."""
    safe = char_name.lower().replace(" ", "_")
    scene_suffix = scene_id.split("_")[-1] if scene_id else "001"

    candidates = [
        os.path.join(IMAGE_DIR, f"{safe}__{scene_id}_.jpg"),
        os.path.join(IMAGE_DIR, f"{safe}__scene_{scene_suffix}_.jpg"),
        os.path.join("image_assets", f"{safe}__{scene_id}_.jpg"),
        os.path.join("image_assets", f"{safe}__scene_{scene_suffix}_.jpg"),
    ]
    for p in candidates:
        if os.path.exists(p):
            return p

    if os.path.isdir(IMAGE_DIR):
        for fname in sorted(os.listdir(IMAGE_DIR)):
            if fname.startswith(safe) and fname.endswith(".jpg"):
                return os.path.join(IMAGE_DIR, fname)

    return os.path.join("image_assets", f"{safe}__scene_001_.jpg")

