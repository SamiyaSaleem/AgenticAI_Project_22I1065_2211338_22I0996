async def scene_parser_node(state: OverallState):
    print("\n[Scene Parser Agent] Parsing manifest into parallel tasks...")
    # Use LLM with parser model
    llm = get_llm("parser")
    if llm:
        print(f"  -> Using LLM: {MODELS['parser']}")

    raw = await call_mcp_tool(mcp_session, "get_task_graph", {"scene_manifest_path": state["scene_manifest_path"]})
    res = json.loads(raw)
    tasks = res.get("tasks", [])

    # Debug: show what the task graph returned
    print(f"  -> Raw tasks count from get_task_graph: {len(tasks)}")
    if len(tasks) > 0:
        try:
            print(f"  -> Sample task keys: {list(tasks[0].keys())}")
            print(f"  -> Sample task preview: {json.dumps(tasks[0])[:400]}")
        except Exception:
            print("  -> Sample task (raw):", str(tasks[0])[:400])

    # Fallback: if tasks don't include dialogue data, build tasks directly from scene_manifest.json
    has_dialogues = any(t.get("dialogues") or t.get("dialogue") for t in tasks)
    if not has_dialogues:
        print("  -> get_task_graph returned tasks with no dialogue; falling back to scene_manifest.json")
        scenes = load_json(os.path.basename(state["scene_manifest_path"])) or []
        tasks = []
        for i, s in enumerate(scenes):
            tasks.append({
                "task_id": s.get("scene_id", f"task_{i+1}"),
                "scene_id": s.get("scene_id", f"scene_{i+1}"),
                "description": s.get("action", s.get("location", "")),
                "characters": s.get("characters", []),
                "dialogues": s.get("dialogue", []),
            })
        print(f"  -> Fallback created {len(tasks)} tasks from scene_manifest.json")

    # Save intermediate output using commit_memory (Assignment 4 Section 3.3 - Stateful Resumability)
    await call_mcp_tool(mcp_session, "commit_memory", {
        "collection_name": "phase2_task_graph",
        "documents": [json.dumps({"tasks": tasks, "timestamp": str(asyncio.get_event_loop().time())})],
        "metadatas": [{"type": "task_graph", "task_count": len(tasks)}],
    })

    print(f"  -> Generated {len(tasks)} tasks and committed to memory.")
    print(f"  -> Task IDs: {[t['task_id'] for t in tasks]}")
    return {"tasks": tasks}


async def voice_synth_node(state: SceneState):
    task = state["task"]
    print(
        f"\n[Voice Synthesis Agent] Processing {task['scene_id']} (Parallel Branch 1)")

    llm = get_llm("voice")
    if llm:
        print(f"  -> Using LLM: {MODELS['voice']}")
    # Accept either 'dialogues' (phase2 task graph) or 'dialogue' (phase1 manifest)
    audio_paths = []
    dialogue_segments = []
    dialogues = task.get("dialogues") or task.get("dialogue") or []

    # Debug: show how many dialogue entries we received and a sample
    print(f"  -> Dialogues found: {len(dialogues)}")
    if len(dialogues) > 0:
        sample = dialogues[0]
        try:
            print(f"  -> Sample dialogue entry keys: {list(sample.keys())}")
        except Exception:
            print(f"  -> Sample dialogue (raw): {str(sample)[:200]}")

    for diag in dialogues:
        speaker = diag.get("speaker", "UNKNOWN")
        line = diag.get("line", "")

        emotion = "neutral"
        if llm:
            try:
                resp = await llm.ainvoke([
                    SystemMessage(
                        content="Reply with exactly one word representing the emotion (e.g., angry, sad)."),
                    HumanMessage(content=f"Line: {line}")
                ])
                emotion = ''.join(
                    e for e in resp.content.strip().lower() if e.isalnum())
            except:
                pass

        # Emotion-aware adjustments for rate and pitch
        rate = "+0%"
        pitch = "+0Hz"
        
        emo_lower = emotion.lower()
        if emo_lower in ["angry", "urgent", "frustrated"]:
            rate = "+15%"
            pitch = "+10Hz"
        elif emo_lower in ["sad", "cautious", "nervous"]:
            rate = "-10%"
            pitch = "-10Hz"

        raw = await call_mcp_tool(mcp_session, "voice_cloning_synthesizer", {
            "character_name": speaker,
            "dialogue": line,
            "emotion": emotion,
            "rate": rate,
            "pitch": pitch
        })
        res = json.loads(raw)
        if res.get("status") == "success":
            apath = res.get("audio_path")
            audio_paths.append(apath)
            dialogue_segments.append({
                "speaker": speaker,
                "line": line,
                "audio_path": apath,
            })
            try:
                fname = os.path.basename(apath) if apath else "(unknown)"
            except Exception:
                fname = str(apath)
            print(f"  -> Audio for {speaker}: {apath}  (file: {fname})")

    return {"audio_paths": audio_paths, "dialogue_segments": dialogue_segments}


async def video_gen_node(state: SceneState):
    task = state["task"]
    print(
        f"\n[Video Generation Agent] Processing {task['scene_id']} (Parallel Branch 2)")

    llm = get_llm("video")
    if llm:
        print(f"  -> Using LLM: {MODELS['video']}")
        try:
            resp = await llm.ainvoke([
                SystemMessage(
                    content="Extract a core visual aesthetic keyword from the description."),
                HumanMessage(content=task.get("description", ""))
            ])
            keyword = resp.content.strip()
        except:
            keyword = "cinematic"
    else:
        keyword = "cinematic"

    raw = await call_mcp_tool(mcp_session, "query_stock_footage", {
        "description": f"{task['scene_id']} {keyword} environment"
    })
    res = json.loads(raw)
    base_vid = res.get("matched_footage", "stock_default.mp4")
    print(f"  -> Base environment generated: {base_vid}")

    # Debug: check whether base_vid exists locally (common cause of static frames)
    try:
        exists = os.path.exists(base_vid)
    except Exception:
        exists = False
    print(f"  -> Base video exists on disk: {exists} (checked path: {base_vid})")

    return {"base_video": base_vid}


async def face_swap_node(state: SceneState):
    task = state["task"]
    base_vid = state.get("base_video", "")
    print(
        f"\n[Face Swap Agent] Frame-by-frame processing for {task['scene_id']}")

    if not base_vid or not os.path.exists(base_vid):
        print(f"  -> Base video missing, skipping face swap: {base_vid}")
        return {"swapped_video": base_vid}

    scene_id = task.get("scene_id", "scene_001")
    chars = task.get("characters", [])
    current_video = base_vid

    for char_name in chars:
        image_path = find_character_image(char_name, scene_id)

        # CRITICAL: Validate identity before face mapping (Assignment 4 Section 5.4)
        print(
            f"  -> Frame-by-frame processing: Validating identity for {char_name}...")
        validation_raw = await call_mcp_tool(mcp_session, "identity_validator", {
            "character_name": char_name,
            "image_path": image_path
        })
        validation_res = json.loads(validation_raw)

        if not validation_res.get("is_valid"):
            print(
                f"  -> Identity validation FAILED for {char_name}. Skipping this character.")
            continue

        print(
            f"  -> Identity validated: {char_name} (confidence: {validation_res.get('confidence')})")

        # Chain swaps so all scene characters are applied on the same evolving video.
        raw = await call_mcp_tool(mcp_session, "face_swapper", {
            "source_image": image_path,
            "target_media": current_video
        })
        try:
            print(f"  -> face_swapper raw response: {raw}")
        except Exception:
            print("  -> face_swapper returned non-serializable response")
        res = json.loads(raw)
        swapped = res.get("swapped_media", current_video)
        print(f"  -> Swapped video ({char_name}): {swapped}")

        try:
            s_exists = os.path.exists(swapped)
        except Exception:
            s_exists = False
        print(f"  -> Swapped video exists on disk: {s_exists} (path: {swapped})")

        if s_exists:
            current_video = swapped

    return {"swapped_video": current_video}


async def facial_animation_node(state: SceneState):
    """Apply per-frame facial animation (blink, expressions, mouth movement).

    This node calls an MCP tool `facial_animator` if available. It passes the
    swapped video plus dialogue segments so the tool can produce frame-accurate
    mouth motion, blinks, and expression keyframes. If the tool is missing or
    fails, we fall back to returning the input swapped video unchanged.
    """
    task = state.get("task", {})
    swapped = state.get("swapped_video", "")
    segments = state.get("dialogue_segments", [])

    # dialogue_segments is empty when voice branch hasn't merged yet.
    # Build segments directly from task dialogues so facial_animator
    # always receives something to animate against.
    if not segments:
        segments = [
            {
                "speaker": d.get("speaker", ""),
                "line": d.get("line", ""),
                "audio_path": "",
            }
            for d in (task.get("dialogues") or task.get("dialogue") or [])
        ]

    print(f"\n[Facial Animation Agent] Animating faces for {task.get('scene_id')}")
    if not swapped or not os.path.exists(swapped):
        print(f"  -> No swapped video available to animate: {swapped}")
        return {"swapped_video": swapped}

    # Prepare animation request
    args = {
        "video_path": swapped,
        "dialogue_segments": segments,
        "options": {
            "blink": True,
            "mouth_sync": True,
            "expressions": "auto",  # let the tool infer expression cues
            "frame_by_frame": True,
        }
    }

    # Call MCP tool if available
    raw = await call_mcp_tool(mcp_session, "facial_animator", args)
    try:
        print(f"  -> facial_animator raw response: {raw}")
    except Exception:
        print("  -> facial_animator returned non-serializable response")

    try:
        res = json.loads(raw)
    except Exception:
        print("  -> facial_animator returned non-JSON response; skipping animation")
        return {"swapped_video": swapped}

    if res.get("status") == "success" and res.get("animated_media"):
        animated = res.get("animated_media")
        print(f"  -> Animated video produced: {animated}")
        try:
            a_exists = os.path.exists(animated)
        except Exception:
            a_exists = False
        print(f"  -> Animated video exists on disk: {a_exists} (path: {animated})")
        return {"swapped_video": animated if a_exists else swapped}

    print("  -> facial_animator did not produce animated output; using swapped video")
    return {"swapped_video": swapped}


async def lip_sync_node(state: SceneState):
    task = state["task"]
    audio_paths = state.get("audio_paths", [])
    dialogue_segments = state.get("dialogue_segments", [])
    swapped_vid = state.get("swapped_video", "")
    print(f"\n[Lip Sync Agent] Temporal Alignment for {task['scene_id']}")

    # Guard: this node can be triggered before face-swap finishes in parallel graphs.
    # Skip until we have a real swapped video path.
    if not swapped_vid or not os.path.exists(swapped_vid):
        print(f"  -> Lip sync deferred: swapped video not ready ({swapped_vid})")
        return {"final_synced_video": ""}

    if not audio_paths and not dialogue_segments:
        print("  -> Lip sync deferred: audio not ready")
        return {"final_synced_video": ""}

    # Build ordered sequence for all dialogue turns.
    if dialogue_segments:
        sequence = [
            (seg.get("speaker", "UNKNOWN"), seg.get("audio_path", ""))
            for seg in dialogue_segments
            if seg.get("audio_path")
        ]
    else:
        fallback_char = task.get("characters", ["UNKNOWN"])[0]
        sequence = [(fallback_char, p) for p in audio_paths if p]

    if not sequence:
        print("  -> Lip sync deferred: no usable audio segments")
        return {"final_synced_video": ""}

    current_video = swapped_vid
    for idx, (speaker, audio_path) in enumerate(sequence, start=1):
        print(f"  -> Lip sync segment {idx}/{len(sequence)} speaker={speaker}")
        raw = await call_mcp_tool(mcp_session, "lip_sync_aligner", {
            "audio_path": audio_path,
            "video_path": current_video,
            "character_name": speaker
        })
        # Debug: print raw lip_sync response
        try:
            print(f"  -> lip_sync_aligner raw response: {raw}")
        except Exception:
            print("  -> lip_sync_aligner returned non-serializable response")

        res = json.loads(raw)
        if res.get("status") != "success":
            print(f"  -> lip_sync_aligner error detail: {res.get('detail')}")
            continue

        # Ignore pseudo-success where no input video is actually used.
        if not res.get("video_source"):
            print("  -> Lip sync ignored for this segment: empty video_source")
            continue

        synced_candidate = res.get("synced_media", current_video)
        if synced_candidate and os.path.exists(synced_candidate):
            current_video = synced_candidate

    synced = current_video
    print(f"  -> Output synced scene: {synced}")

    # Verify files exist and report
    try:
        synced_exists = os.path.exists(synced)
    except Exception:
        synced_exists = False
    print(f"  -> Synced media exists on disk: {synced_exists} (path: {synced})")

    # If synced file exists, copy/move to RAW_SCENES_DIR for later composition
    try:
        if synced_exists:
            dst = os.path.join(RAW_SCENES_DIR, os.path.basename(synced))
            if os.path.abspath(synced) != os.path.abspath(dst):
                try:
                    with open(synced, 'rb') as sf, open(dst, 'wb') as df:
                        df.write(sf.read())
                    print(f"  -> Copied synced media to: {dst}")
                except Exception:
                    print(f"  -> Failed to copy synced media to {dst}")
    except Exception:
        pass

    return {"final_synced_video": synced}

# ── Subgraph setup ────────────────────────────────────────────────────────────


def build_scene_subgraph():
    """
    Sequential subgraph: Voice -> FaceSwap/Video (sequential, not parallel)
    -> FacialAnimation -> LipSync.

    Running Voice first then Video+FaceSwap sequentially eliminates the
    double-firing problem that occurs when two parallel branches converge
    on a single node in LangGraph. dialogue_segments is fully populated
    before facial_animation_node runs.
    """
    builder = StateGraph(SceneState)
    builder.add_node("Voice_synth_node", voice_synth_node)
    builder.add_node("Video_gen_node", video_gen_node)
    builder.add_node("Face_swap_node", face_swap_node)
    builder.add_node("Facial_animation_node", facial_animation_node)
    builder.add_node("Lip_sync_node", lip_sync_node)

    # Voice runs first so dialogue_segments is ready for facial animation
    builder.add_edge(START, "Voice_synth_node")
    builder.add_edge("Voice_synth_node", "Video_gen_node")
    builder.add_edge("Video_gen_node", "Face_swap_node")
    builder.add_edge("Face_swap_node", "Facial_animation_node")
    builder.add_edge("Facial_animation_node", "Lip_sync_node")
    builder.add_edge("Lip_sync_node", END)

    return builder.compile()


# ── Main Graph Map/Reduce ─────────────────────────────────────────────────────


async def process_scene_node(state: SceneState):
    # Run the parallel subgraph for this specific task
    graph = build_scene_subgraph()
    result = await graph.ainvoke(state)
    return {"final_outputs": [result.get("final_synced_video", "")]}


def map_scenes(state: OverallState):
    # This uses LangGraph's Send() API to branch out in parallel
    return [Send("Process_Scene", {"task": task}) for task in state["tasks"]]


async def main():
    global mcp_session
    print("="*60)
    print("  PHASE II: THE STUDIO FLOOR (Parallel Synthesis)")
    print("="*60)

    server_params = StdioServerParameters(
        command=sys.executable, args=[MCP_SERVER])

    # Track execution logs for comprehensive task graph documentation
    execution_logs = {
        "phase": "Phase 2",
        "title": "The Studio Floor - Parallel Synthesis",
        "timestamp": str(asyncio.get_event_loop().time()),
        "scenes_processed": [],
        "agents_invoked": []
    }

    async with stdio_client(server_params) as (read, write):
        async with ClientSession(read, write) as session:
            await session.initialize()
            mcp_session = session

            # Build Main Graph
            builder = StateGraph(OverallState)
            builder.add_node("Scene_parser_node", scene_parser_node)
            builder.add_node("Process_Scene", process_scene_node)

            builder.add_edge(START, "Scene_parser_node")
            builder.add_conditional_edges("Scene_parser_node", map_scenes)
            # Process_scene outputs are automatically collected into final_outputs

            graph = builder.compile()

            manifest_path = os.path.join(OUTPUT_DIR, "scene_manifest.json")
            if not os.path.exists(manifest_path):
                print("Error: scene_manifest.json not found! Run Phase 1 first.")
