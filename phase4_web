@app.get("/history")
async def get_history():
    """Return the full version history."""
    from phase5_edit_agent import state_manager
    return {"history": state_manager.history()}


@app.post("/undo")
async def undo(req: UndoRequest):
    """Undo to a specific version or the previous version."""
    from phase5_edit_agent import state_manager
    result = state_manager.revert(req.version)
    await broadcast("undo", {"version": result.get("version"), "description": result.get("description")})
    return result


@app.get("/version/{version_id}")
async def get_version(version_id: int):
    """Get details of a specific version."""
    from phase5_edit_agent import state_manager
    history = state_manager.history()
    matches = [v for v in history if v["version"] == version_id]
    if not matches:
        raise HTTPException(status_code=404, detail="Version not found")
    return matches[0]


