@app.post("/generate")
async def generate(req: PromptRequest, background_tasks: BackgroundTasks):
    """Start the full pipeline from a user prompt."""
    if pipeline_status["running"]:
        raise HTTPException(status_code=409, detail="Pipeline already running")
    background_tasks.add_task(run_pipeline, req.prompt, req.mode)
    return {"message": "Pipeline started", "prompt": req.prompt}


@app.get("/status")
async def get_status():
    """Return current pipeline status."""
    return pipeline_status


@app.get("/progress")
async def progress_stream():
    """SSE endpoint for real-time pipeline progress."""
    queue: asyncio.Queue = asyncio.Queue(maxsize=100)
    sse_queues.append(queue)

    async def event_generator():
        # Send current status immediately on connect
        yield f"event: status\ndata: {json.dumps(pipeline_status)}\n\n"
        try:
            while True:
                try:
                    msg = await asyncio.wait_for(queue.get(), timeout=30)
                    yield msg
                except asyncio.TimeoutError:
                    yield ": keepalive\n\n"
        except asyncio.CancelledError:
            pass
        finally:
            if queue in sse_queues:
                sse_queues.remove(queue)

    return StreamingResponse(
        event_generator(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "X-Accel-Buffering": "no",
        }
    )


@app.post("/rerun/{phase}")
async def rerun_phase(phase: str, background_tasks: BackgroundTasks):
    """Re-run a specific pipeline phase."""
    if phase not in ("phase1", "phase2", "phase3"):
        raise HTTPException(status_code=400, detail="Invalid phase")
    if pipeline_status["running"]:
        raise HTTPException(status_code=409, detail="Pipeline already running")
    background_tasks.add_task(run_single_phase, phase)
    return {"message": f"{phase} re-run started"}


@app.get("/video/{filename}")
async def get_video(filename: str):
    """Stream the final video."""
    path = os.path.join(BASE_DIR, filename)
    if not os.path.exists(path):
        raise HTTPException(status_code=404, detail="Video not found")
    return FileResponse(path, media_type="video/mp4")


@app.get("/download/{filename}")
async def download_file(filename: str):
    """Download a generated file."""
    # Whitelist safe files
    allowed = {"final_output.mp4", "scene_manifest.json", "timing_manifest.json", "character_db.json"}
    if filename not in allowed:
        raise HTTPException(status_code=403, detail="File not allowed")
    path = os.path.join(BASE_DIR, filename)
    if not os.path.exists(path):
        raise HTTPException(status_code=404, detail="File not found")
    return FileResponse(path, filename=filename)


@app.get("/assets")
async def list_assets():
    """Return a list of generated assets."""
    assets = {}
    for fname in ("scene_manifest.json", "timing_manifest.json", "character_db.json"):
        path = os.path.join(BASE_DIR, fname)
        assets[fname] = os.path.exists(path)
    video_path = os.path.join(BASE_DIR, "final_output.mp4")
    assets["final_output.mp4"] = os.path.exists(video_path)
    if os.path.exists(video_path):
        assets["video_size_mb"] = round(os.path.getsize(video_path) / (1024*1024), 2)

    # Audio files
    audio_dir = os.path.join(BASE_DIR, "audio_assets")
    assets["audio_count"] = len(os.listdir(audio_dir)) if os.path.isdir(audio_dir) else 0

    # Images
    image_dir = os.path.join(BASE_DIR, "image_assets")
    assets["image_count"] = len(os.listdir(image_dir)) if os.path.isdir(image_dir) else 0

    return assets


