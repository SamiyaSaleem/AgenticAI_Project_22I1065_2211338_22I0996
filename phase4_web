# ── Global pipeline state ─────────────────────────────────────────────────────
pipeline_status: Dict[str, Any] = {
    "running": False,
    "current_phase": None,
    "phases": {
        "phase1": {"status": "idle", "message": ""},
        "phase2": {"status": "idle", "message": ""},
        "phase3": {"status": "idle", "message": ""},
    },
    "prompt": "",
    "error": None,
    "finished": False,
}

# SSE subscriber queues
sse_queues: List[asyncio.Queue] = []

# ── Pydantic models ───────────────────────────────────────────────────────────
class PromptRequest(BaseModel):
    prompt: str
    mode: Optional[str] = "auto"

class EditRequest(BaseModel):
    query: str

class UndoRequest(BaseModel):
    version: Optional[int] = None  # None = undo last

# ── SSE helpers ───────────────────────────────────────────────────────────────
async def broadcast(event: str, data: dict):
    """Push an SSE event to all connected clients."""
    msg = f"event: {event}\ndata: {json.dumps(data)}\n\n"
    dead = []
    for q in sse_queues:
        try:
            q.put_nowait(msg)
        except asyncio.QueueFull:
            dead.append(q)
    for q in dead:
        sse_queues.remove(q)


def update_phase(phase: str, status: str, message: str):
    """Update global pipeline status and broadcast to SSE clients."""
    pipeline_status["phases"][phase] = {"status": status, "message": message}
    pipeline_status["current_phase"] = phase
    asyncio.get_event_loop().create_task(
        broadcast("phase_update", {
            "phase": phase,
            "status": status,
            "message": message,
            "timestamp": datetime.now().isoformat(),
        })
    )


# ── Pipeline runner ───────────────────────────────────────────────────────────
async def run_pipeline(prompt: str, mode: str = "auto"):
    """Execute all pipeline phases sequentially with SSE progress updates."""
    global pipeline_status
    pipeline_status["running"] = True
    pipeline_status["finished"] = False
    pipeline_status["error"] = None
    pipeline_status["prompt"] = prompt

    await broadcast("pipeline_start", {"prompt": prompt, "mode": mode})

    try:
        # ── Phase 1: Story & Script ───────────────────────────────────────────
        update_phase("phase1", "running", "Generating story, script, and characters...")
        try:
            from main import run_workflow
            await run_workflow(prompt)
            update_phase("phase1", "done", "Story, script, and character DB generated ✓")
            await broadcast("phase_done", {"phase": "phase1", "output": "scene_manifest.json"})
        except Exception as e:
            update_phase("phase1", "error", f"Phase 1 error: {str(e)}")
            await broadcast("error", {"phase": "phase1", "message": str(e)})
            pipeline_status["error"] = str(e)
            return

        # ── Phase 2: Audio Generation ─────────────────────────────────────────
        update_phase("phase2", "running", "Synthesising character voices and audio...")
        try:
            from phase2_pipeline import run_phase2
            await run_phase2()
            update_phase("phase2", "done", "Audio files and timing manifest generated ✓")
            await broadcast("phase_done", {"phase": "phase2", "output": "timing_manifest.json"})
        except Exception as e:
            update_phase("phase2", "error", f"Phase 2 error: {str(e)}")
            await broadcast("error", {"phase": "phase2", "message": str(e)})
            pipeline_status["error"] = str(e)
            return

        # ── Phase 3: Video Composition ────────────────────────────────────────
        update_phase("phase3", "running", "Composing animated video with Ken Burns effects...")
        try:
            from phase3_pipeline import main as run_phase3
            await run_phase3()
            update_phase("phase3", "done", "final_output.mp4 rendered ✓")
            await broadcast("phase_done", {"phase": "phase3", "output": "final_output.mp4"})
        except Exception as e:
            update_phase("phase3", "error", f"Phase 3 error: {str(e)}")
            await broadcast("error", {"phase": "phase3", "message": str(e)})
            pipeline_status["error"] = str(e)
            return

        # ── Take initial state snapshot for undo system ───────────────────────
        from phase5_edit_agent import state_manager
        state_manager.snapshot(
            description=f"Initial generation: {prompt[:60]}",
            assets={
                "scene_manifest": os.path.join(BASE_DIR, "scene_manifest.json"),
                "timing_manifest": os.path.join(BASE_DIR, "timing_manifest.json"),
                "final_output": os.path.join(BASE_DIR, "final_output.mp4"),
            }
        )

        pipeline_status["finished"] = True
        await broadcast("pipeline_complete", {
            "message": "Pipeline complete! Your animated video is ready.",
            "video_url": "/video/final_output.mp4",
        })

    except Exception as e:
        pipeline_status["error"] = str(e)
        await broadcast("error", {"message": str(e)})
    finally:
        pipeline_status["running"] = False


async def run_single_phase(phase: str, **kwargs):
    """Re-run a single pipeline phase (for phase-level re-run buttons)."""
    update_phase(phase, "running", f"Re-running {phase}...")
    try:
        if phase == "phase1":
            from main import run_workflow
            prompt = kwargs.get("prompt", pipeline_status.get("prompt", ""))
            await run_workflow(prompt)
        elif phase == "phase2":
            from phase2_pipeline import run_phase2
            await run_phase2()
        elif phase == "phase3":
            from phase3_pipeline import main as run_phase3
            await run_phase3()
        update_phase(phase, "done", f"{phase} re-run complete ✓")
        await broadcast("phase_done", {"phase": phase, "rerun": True})
    except Exception as e:
        update_phase(phase, "error", str(e))
        await broadcast("error", {"phase": phase, "message": str(e)})


