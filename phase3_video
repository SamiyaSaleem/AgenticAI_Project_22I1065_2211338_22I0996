# ── Directories ───────────────────────────────────────────────────────────────
OUTPUT_DIR    = os.path.dirname(os.path.abspath(__file__))
IMAGE_DIR     = os.path.join(OUTPUT_DIR, "image_assets")
AUDIO_DIR     = os.path.join(OUTPUT_DIR, "audio_assets")
