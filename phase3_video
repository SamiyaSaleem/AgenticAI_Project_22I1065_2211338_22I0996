os.makedirs(RAW_SCENES_DIR, exist_ok=True)

# ── Video settings ────────────────────────────────────────────────────────────
VID_W, VID_H = 854, 480
FPS          = 24
ZOOM_FACTOR  = 0.12          # 12 % Ken-Burns zoom over the clip
CROSSFADE_S  = 0.4           # crossfade between scenes (seconds)

# ── Voice profiles (character → edge-tts voice) ───────────────────────────────
VOICE_MAP: Dict[str, str] = {
    "JEN":            "en-US-JennyNeural",
    "MIKE":           "en-US-GuyNeural",
    "PRINCIPAL SMITH":"en-US-ChristopherNeural",
    "KAI":            "en-US-GuyNeural",
