    "script":      execute_script_edit,
}


class EditAgent:
    """
    LangGraph-style edit agent.

    Nodes:
      1. classify  → determines intent + target from free-text query
      2. execute   → runs the appropriate phase re-run
      3. snapshot  → saves a state version for undo

    The agent is implemented as a simple async chain (not full LangGraph graph)
    to keep dependencies minimal, but follows the same node-edge pattern.
    """

    async def process_edit(self, query: str) -> Dict:
        print(f"\n[EditAgent] Processing: '{query}'")

        # Node 1: Classify intent
        intent_obj = await classify_intent_llm(query)
        print(f"[EditAgent] Intent: {intent_obj}")

        # Node 2: Execute
        target = intent_obj.get("target", "video")
        executor = EXECUTORS.get(target, execute_video_edit)
        result = await executor(intent_obj)
        print(f"[EditAgent] Result: {result}")

        # Node 3: Snapshot for undo
        if result.get("status") == "success":
            assets = {
                "scene_manifest": os.path.join(BASE_DIR, "scene_manifest.json"),
                "timing_manifest": os.path.join(BASE_DIR, "timing_manifest.json"),
                "final_output": os.path.join(BASE_DIR, "final_output.mp4"),
            }
            version = state_manager.snapshot(
                description=f"Edit: {query[:80]}",
                assets=assets,
            )
            result["version"] = version

        return {
            "query": query,
            "intent": intent_obj,
            "execution": result,
        }


