async def execute_audio_edit(intent_obj: Dict) -> Dict:
    """Re-run TTS synthesis for the affected scene/character."""
    scope = intent_obj.get("scope", "all")
    print(f"[Execute] Audio edit: scope={scope}")

    # Load scene manifest
    manifest_path = os.path.join(BASE_DIR, "scene_manifest.json")
    if not os.path.exists(manifest_path):
        return {"status": "error", "message": "scene_manifest.json not found"}

    with open(manifest_path, encoding="utf-8") as f:
        manifest = json.load(f)

    # Filter to target scenes
    if scope.startswith("character:"):
        char = scope.split(":")[1].upper()
        target_scenes = [
            s for s in manifest
            if any(c.upper() == char for c in s.get("characters", []))
        ]
    elif scope != "all":
        target_scenes = [s for s in manifest if s["scene_id"] == scope]
    else:
        target_scenes = manifest

    # Re-synthesise audio for those scenes using edge-tts
    try:
        import edge_tts
        audio_dir = os.path.join(BASE_DIR, "audio_assets")
        new_files = []

        for scene in target_scenes:
            for dlg in scene.get("dialogue", []):
                speaker = dlg.get("speaker", "DEFAULT").upper()
                line = dlg.get("line", "")
                voice = "en-US-AriaNeural"  # default
                # Simple voice map
                voice_map = {
                    "KAI": "en-US-GuyNeural",
                    "LENA": "en-US-JennyNeural",
                    "ADA": "en-US-AriaNeural",
                    "NARRATOR": "en-US-ChristopherNeural",
                }
                voice = voice_map.get(speaker, voice_map.get(
                    next((k for k in voice_map if k in speaker), "DEFAULT"), "en-US-AriaNeural"
                ))

                fname = f"edit_{speaker.lower()}_{uuid.uuid4().hex[:6]}.mp3"
                fpath = os.path.join(audio_dir, fname)
                communicate = edge_tts.Communicate(line, voice)
                await communicate.save(fpath)
                new_files.append(fpath)

        return {
            "status": "success",
            "message": f"Re-synthesised {len(new_files)} audio file(s)",
            "files": new_files,
        }
    except Exception as e:
        return {"status": "error", "message": str(e)}


async def execute_video_frame_edit(intent_obj: Dict) -> Dict:
    """Re-generate scene image(s) with updated visual descriptor."""
    scope = intent_obj.get("scope", "all")
    intent = intent_obj.get("intent", "")
    print(f"[Execute] Video frame edit: scope={scope}, intent={intent}")

    # Build an aesthetic modifier based on intent
    aesthetic_mod = ""
    if "darker" in intent:
        aesthetic_mod = "dark, moody, low-key lighting, deep shadows"
    elif "brighter" in intent:
        aesthetic_mod = "bright, vivid, high-key lighting, vibrant colors"
    elif "character_design" in intent:
        aesthetic_mod = "detailed character portrait, new outfit design"
    elif "style" in intent:
        aesthetic_mod = "new artistic style, stylized rendering"
    else:
        aesthetic_mod = "updated aesthetic"

    # Load scene manifest to get visual descriptions
    manifest_path = os.path.join(BASE_DIR, "scene_manifest.json")
    if not os.path.exists(manifest_path):
        return {"status": "error", "message": "scene_manifest.json not found"}

    with open(manifest_path, encoding="utf-8") as f:
        manifest = json.load(f)

    if scope.startswith("character:"):
        char = scope.split(":")[1].upper()
        target_scenes = [s for s in manifest if any(c.upper() == char for c in s.get("characters", []))]
    elif scope != "all":
        target_scenes = [s for s in manifest if s["scene_id"] == scope]
    else:
        target_scenes = manifest

    # Generate updated placeholder images
    try:
        from PIL import Image, ImageDraw, ImageFont
        image_dir = os.path.join(BASE_DIR, "image_assets")
        regenerated = []

        for scene in target_scenes:
            scene_id = scene["scene_id"]
            location = scene.get("location", "")
            chars = scene.get("characters", [])

            # Create updated scene composite image
            img = Image.new("RGB", (854, 480))
            draw = ImageDraw.Draw(img)

            # Apply aesthetic modification to background colour
            if "dark" in aesthetic_mod:
                bg = (10, 10, 30)
                accent = (80, 40, 120)
            elif "bright" in aesthetic_mod:
                bg = (200, 220, 255)
                accent = (255, 200, 100)
            else:
                bg = (30, 30, 60)
                accent = (100, 80, 180)

            # Gradient background
            for y in range(480):
                t = y / 479
                r = int(bg[0] * (1-t) + accent[0] * t)
                g = int(bg[1] * (1-t) + accent[1] * t)
                b = int(bg[2] * (1-t) + accent[2] * t)
                draw.line([(0, y), (854, y)], fill=(r, g, b))

            # Overlay text labels
            draw.text((20, 20), f"[EDITED] {scene_id}", fill=(255, 255, 255))
            draw.text((20, 50), location[:60], fill=(200, 200, 200))
            draw.text((20, 80), f"Style: {aesthetic_mod[:40]}", fill=(180, 220, 180))
            for i, ch in enumerate(chars):
                draw.text((20, 120 + i*30), f"• {ch}", fill=(220, 220, 255))

            # Save
            fname = f"edited_{scene_id}_{uuid.uuid4().hex[:4]}.jpg"
            fpath = os.path.join(image_dir, fname)
            img.save(fpath, "JPEG", quality=90)
            regenerated.append(fpath)

        return {
            "status": "success",
            "message": f"Re-generated {len(regenerated)} scene image(s) with: {aesthetic_mod}",
            "files": regenerated,
        }
    except Exception as e:
        return {"status": "error", "message": str(e)}


