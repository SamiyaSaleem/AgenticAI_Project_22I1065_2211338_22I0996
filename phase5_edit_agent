class StateManager:
    """
    Append-only version log.

    Each snapshot stores:
      - version   : int counter (1, 2, 3 …)
      - description: human-readable summary of what changed
      - timestamp : ISO-8601
      - assets    : dict mapping logical name → file path
      - state_json: full pipeline JSON state at that moment
    """

    def __init__(self):
        self._load_index()

    def _load_index(self):
        if os.path.exists(VERSIONS_INDEX):
            with open(VERSIONS_INDEX, "r", encoding="utf-8") as f:
                self._index: List[Dict] = json.load(f)
        else:
            self._index = []

    def _save_index(self):
        with open(VERSIONS_INDEX, "w", encoding="utf-8") as f:
            json.dump(self._index, f, indent=2)

    def snapshot(self, description: str, assets: Optional[Dict[str, str]] = None) -> int:
        """
        Save a snapshot of the current state.

        Parameters
        ----------
        description : str
            Human-readable label for this version.
        assets : dict, optional
            Mapping of logical name → source file path to copy into the snapshot.

        Returns
        -------
        int : the new version number
        """
        version = len(self._index) + 1
        snap_dir = os.path.join(VERSIONS_DIR, f"v{version:03d}")
        os.makedirs(snap_dir, exist_ok=True)

        copied_assets: Dict[str, str] = {}

        # Copy each asset into the snapshot directory
        if assets:
            for name, src in assets.items():
                if src and os.path.exists(src):
                    dst = os.path.join(snap_dir, os.path.basename(src))
                    shutil.copy2(src, dst)
                    copied_assets[name] = dst

        # Collect current pipeline JSON state
        state_json = self._collect_state()
        state_path = os.path.join(snap_dir, "state.json")
        with open(state_path, "w", encoding="utf-8") as f:
            json.dump(state_json, f, indent=2)

        entry = {
            "version": version,
            "description": description,
            "timestamp": datetime.now().isoformat(),
            "snap_dir": snap_dir,
            "state_path": state_path,
            "assets": copied_assets,
        }
        self._index.append(entry)
        self._save_index()
        print(f"[StateManager] Snapshot v{version}: {description}")
        return version

    def revert(self, version: Optional[int] = None) -> Dict:
        """
        Revert to a specific version (or the previous version if None).

        Copies snapshotted assets back to their original locations and
        restores the pipeline JSON state files.
        """
        self._load_index()
        if not self._index:
            return {"error": "No versions available to revert to"}

        if version is None:
            # Undo = go back one step from current
            target = self._index[-2] if len(self._index) >= 2 else self._index[0]
        else:
            matches = [v for v in self._index if v["version"] == version]
            if not matches:
                return {"error": f"Version {version} not found"}
            target = matches[0]

        # Restore assets
        restored = []
        for name, snap_path in target.get("assets", {}).items():
            if os.path.exists(snap_path):
                # Determine the live destination
                dest_map = {
                    "scene_manifest": os.path.join(BASE_DIR, "scene_manifest.json"),
                    "timing_manifest": os.path.join(BASE_DIR, "timing_manifest.json"),
                    "final_output": os.path.join(BASE_DIR, "final_output.mp4"),
                    "character_db": os.path.join(BASE_DIR, "character_db.json"),
                }
                dest = dest_map.get(name, os.path.join(BASE_DIR, os.path.basename(snap_path)))
                shutil.copy2(snap_path, dest)
                restored.append(name)

        # Restore state JSON
        state_path = target.get("state_path")
        if state_path and os.path.exists(state_path):
            with open(state_path, "r", encoding="utf-8") as f:
                state = json.load(f)
            # Write back individual JSON files if they were part of state
            for key in ("scene_manifest", "timing_manifest"):
                if key in state:
                    out = os.path.join(BASE_DIR, f"{key}.json")
                    with open(out, "w", encoding="utf-8") as f:
                        json.dump(state[key], f, indent=2)

        print(f"[StateManager] Reverted to v{target['version']}: {target['description']}")
        return {
            "version": target["version"],
            "description": target["description"],
            "timestamp": target["timestamp"],
            "restored": restored,
        }

    def history(self) -> List[Dict]:
        """Return the full version history (newest first)."""
        self._load_index()
        return list(reversed(self._index))

    def _collect_state(self) -> Dict:
        """Gather current pipeline JSON files into a single dict."""
        state = {}
        for fname, key in [
            ("scene_manifest.json", "scene_manifest"),
            ("timing_manifest.json", "timing_manifest"),
            ("character_db.json", "character_db"),
        ]:
            path = os.path.join(BASE_DIR, fname)
            if os.path.exists(path):
                try:
                    with open(path, "r", encoding="utf-8") as f:
                        state[key] = json.load(f)
                except Exception:
                    pass
        return state


