def classify_intent_rules(query: str) -> Dict[str, Any]:
    """
    Rule-based intent classifier (fast, no LLM needed).
    Matches on keywords in the lower-cased query.
    Returns an intent object.
    """
    q = query.lower()

    for keywords, intent_key in KEYWORD_RULES:
        if any(kw in q for kw in keywords):
            target, description = INTENT_MAP[intent_key]

            # Extract scope hints
            scope = "all"
            for word in ["scene_001", "scene_002", "scene_003", "scene 1", "scene 2", "scene 3"]:
                if word in q:
                    scope = word.replace(" ", "_")
                    break

            # Extract character name hints
            char = None
            manifest_path = os.path.join(BASE_DIR, "scene_manifest.json")
            if os.path.exists(manifest_path):
                try:
                    with open(manifest_path) as f:
                        manifest = json.load(f)
                    all_chars = set()
                    for scene in manifest:
                        for ch in scene.get("characters", []):
                            all_chars.add(ch.lower())
                    for ch in all_chars:
                        if ch in q:
                            char = ch
                            scope = f"character:{ch}"
                            break
                except Exception:
                    pass

            return {
                "intent": intent_key,
                "target": target,
                "scope": scope,
                "character": char,
                "description": description,
                "raw_query": query,
                "classifier": "rules",
            }

    return {
        "intent": "unknown",
        "target": "video",
        "scope": "all",
        "character": None,
        "description": "Unknown intent – defaulting to full video recompose",
        "raw_query": query,
        "classifier": "rules",
    }


async def classify_intent_llm(query: str) -> Dict[str, Any]:
    """
    LLM-based intent classifier using Groq (falls back to rule-based if unavailable).
    Uses a different model from Phase 1-3 agents (llama-3.1-8b-instant for speed).
    """
    api_key = os.getenv("GROQ_API_KEY", "").strip()
    if not api_key:
        return classify_intent_rules(query)

    try:
        from langchain_groq import ChatGroq
        from langchain_core.messages import HumanMessage, SystemMessage

        # Phase 5 uses llama-3.1-8b-instant (distinct from Phase 1's 70b-versatile)
        llm = ChatGroq(
            temperature=0,
            model_name="llama-3.1-8b-instant",
            groq_api_key=api_key
        )

        system = """You are an edit-intent classifier for an AI video generation system.
Given a user's free-text edit query, output ONLY valid JSON with these fields:
{
  "intent": "<one of: change_voice_tone|change_voice_speed|add_background_music|remove_background_music|change_voice_character|make_scene_darker|make_scene_brighter|change_character_design|change_scene_style|change_background|remove_subtitle|add_subtitle|speed_up_scene|slow_down_scene|add_transition|change_aspect_ratio|regenerate_script|change_story_tone|add_scene|unknown>",
  "target": "<one of: audio|video_frame|video|script>",
  "scope": "<scene_001|scene_002|all|character:NAME>",
  "parameters": {}
}
Output ONLY the JSON object. No explanation."""

        resp = llm.invoke([
            SystemMessage(content=system),
            HumanMessage(content=f"Edit query: {query}"),
        ])

        raw = resp.content.strip()
        # Strip markdown code fences if present
        if raw.startswith("```"):
            raw = raw.split("```")[1]
            if raw.startswith("json"):
                raw = raw[4:]
        parsed = json.loads(raw.strip())

        # Enrich with description
        intent_key = parsed.get("intent", "unknown")
        target, desc = INTENT_MAP.get(intent_key, ("video", "Unknown intent"))
        parsed["target"] = target
        parsed["description"] = desc
        parsed["raw_query"] = query
        parsed["classifier"] = "llm"
        return parsed

    except Exception as e:
        print(f"[EditAgent] LLM classifier failed ({e}), using rules")
        return classify_intent_rules(query)


